# Biopunk Flipdot Display — environment variables
# Copy this file to .env and fill in real values.
#   cp .env.example .env

# Flask secret key — CHANGE THIS to a long random string in production
SECRET_KEY=change-me-to-a-random-secret

# Database URL (default: sqlite:///app.db)
# DATABASE_URL=sqlite:///biopunk.db

# ── Flipdot hardware ──────────────────────────────────────────────
# Serial port for the FTDI adapter (omit to auto-detect)
# Use /dev/flipdot if you installed the udev rules.
# FLIPDOT_PORT=/dev/flipdot
# FLIPDOT_BAUD=38400

# ── Voice input (Chapter 7) ──────────────────────────────────────
# Path to the Vosk speech-recognition model directory
# VOSK_MODEL_PATH=./vosk-model
# ALSA device index for the Blue Yeti microphone (omit for default)
# VOSK_DEVICE=
# VOSK_SAMPLE_RATE=16000

# ── Gesture input (Chapter 8) ────────────────────────────────────
# Leap Motion WebSocket endpoint
# LEAP_WS_URL=ws://localhost:6437/v6.json
# Minimum seconds between gesture-triggered messages
# LEAP_COOLDOWN=2.0

# ── Webcam / presence detection (Chapter 9) ──────────────────────
# Video device index (default 0)
# WEBCAM_DEVICE=0
# Motion-detection pixel threshold
# WEBCAM_MOTION_THRESHOLD=5000
# Messages shown when someone arrives / leaves
# WEBCAM_GREETING=WELCOME
# WEBCAM_FAREWELL=GOODBYE
# Seconds before the webcam can trigger again
# WEBCAM_COOLDOWN=30

# ── Webhook ──────────────────────────────────────────────────────
# Shared secret for authenticating incoming webhooks
# WEBHOOK_SECRET=

# ── Playlists (Chapter 12) ───────────────────────────────────────
# Directory containing playlist JSON files
# PLAYLIST_DIR=./playlists

# ── OpenClaw / AI integration (Chapter 14) ───────────────────────
# Anthropic API key (required only when OpenClaw is enabled)
# ANTHROPIC_API_KEY=sk-ant-...
# Model to use for AI-generated messages
# OPENCLAW_MODEL=claude-sonnet-4-6
# Set to "true" to enable the OpenClaw agent
# OPENCLAW_ENABLED=false
# Seconds between autonomous OpenClaw cycles
# OPENCLAW_INTERVAL=300

# ── Generative art (Chapter 15) ──────────────────────────────────
# Seconds between cellular-automaton ticks
# GENERATOR_TICK_RATE=0.3
